# Copy to `.env` and fill in.

# ── Model provider ────────────────────────────────────────────────────────────
# MODEL_PROVIDER controls which LLM to use. Supported values:
#
#   gemini   (default) — Google Gemini via google-adk
#   claude             — Anthropic Claude via LiteLLM (needs google-adk[extensions])
#   openai             — OpenAI via LiteLLM (needs google-adk[extensions])
#
# MODEL_NAME sets the model ID for the chosen provider.
# Leave blank to use the built-in fallback, or set to any model ID from:
#   gemini  → https://ai.google.dev/gemini-api/docs/models
#   claude  → https://docs.anthropic.com/en/docs/about-claude/models
#   openai  → https://platform.openai.com/docs/models

MODEL_PROVIDER=gemini
MODEL_NAME=

# Provide the API key for your chosen provider:
GOOGLE_API_KEY=        # for MODEL_PROVIDER=gemini
# ANTHROPIC_API_KEY=   # for MODEL_PROVIDER=claude
# OPENAI_API_KEY=      # for MODEL_PROVIDER=openai

# ── Local AP3/A2A config ──────────────────────────────────────────────────────
AP3_PORT=10002
CARD_URL=http://localhost:10002
HOST=127.0.0.1
PSI_RECEIVER_URL=http://localhost:10003
