# AP3 A2A Example — environment variables
#
# For LOCAL development defaults are fine — no .env file needed.
# For DOCKER, these are already set in docker-compose.yml.
# Only create a .env if you need to override the defaults.
#
# Copy to .env and edit as needed:
#   cp .env.example .env

# ── Ports (docker-compose) ────────────────────────────────────────────────────
# Override container ports without editing docker-compose.yml.
# COMPANY_A_PORT=10002
# COMPANY_B_PORT=10003

# ── Company A ─────────────────────────────────────────────────────────────────

# Address the server binds to (use 0.0.0.0 to expose outside localhost)
# HOST=127.0.0.1

# Port the server listens on
# PORT=10002

# Public URL where Company A's agent card is reachable by peers
# CARD_URL=http://localhost:10002

# URL of Company B's server (used by psi_client.py)
# COMPANY_B_URL=http://localhost:10003

# ── Company B ─────────────────────────────────────────────────────────────────

# HOST=127.0.0.1
# PORT=10003
# CARD_URL=http://localhost:10003
